<!DOCTYPE html>
<html lang="{{ config.language?.[0] ?? 'en' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    @if(page.title)
      {{ page.title }} | {{ config.title }}
    @else
      {{ config.title }}
    @end
  </title>
  <meta name="description" content="{{ config.description }}">
  <meta name="author" content="{{ config.author }}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  {{-- 导航栏 --}}
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-title">{{ config.title }}</a>
      <nav class="site-nav">
        <a href="/">首页</a>
        <a href="/archives/">归档</a>
        <a href="/about/">关于</a>
      </nav>
    </div>
  </header>

  {{-- 主内容区 --}}
  <main class="site-main">
    <div class="container">
      @!section('content')
    </div>
  </main>

  {{-- 页脚 --}}
  <footer class="site-footer">
    <div class="container">
      <p>&copy; {{ new Date().getFullYear() }} {{ config.author ?? config.title }}. Powered by <a href="https://github.com/nicecai/neo-hexo" target="_blank" rel="noopener">Neo-Hexo</a>.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
